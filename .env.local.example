# =========================================================================
# Yash Makeovers — environment variables
# Copy this file to .env.local and fill in real values.
# In Vercel: Dashboard → Project → Settings → Environment Variables
# Set each one for Production + Preview + Development.
# =========================================================================

# Resend — transactional email
# Get from: resend.com → API Keys
RESEND_API_KEY=

# Cloudinary — image hosting
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=   # same value as above — exposed to the browser for URL building
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Analytics 4
# Get from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=

# WhatsApp — pre-filled message link
NEXT_PUBLIC_WHATSAPP_NUMBER=16476547288

# Availability badge — update this any time. Changing in Vercel triggers a rebuild
# (NEXT_PUBLIC_ vars are inlined at build, not read at runtime).
NEXT_PUBLIC_AVAILABILITY_MSG=Now booking 2026 & 2027 weddings

# Cron security — long random string, e.g. `openssl rand -hex 32`
# Reserved for any future cron-protected route. No active crons today.
CRON_SECRET=

# =========================================================================
# Autonomous blog engine (scripts/ folder + GitHub Actions cron)
# These are only needed for `npm run blog:write` locally. In production they
# live in GitHub repo Secrets, NOT in Vercel env vars.
# =========================================================================

# Anthropic API — powers research + writing
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Email recipient for "new post published" notifications
DEVELOPER_EMAIL=

# =========================================================================
# Feature toggles — default ON. Set to the literal string 'false' to disable.
# Server-only env vars (no NEXT_PUBLIC_ prefix) — primary check happens in
# server components / parents. Requires a redeploy to take effect.
# For the blog engine flag in GitHub Actions, put FEATURE_BLOG_ENGINE in
# GitHub → Settings → Variables (not Secrets) — it's not sensitive.
# =========================================================================
FEATURE_WHATSAPP=true
FEATURE_FEATURED_GRID=true
FEATURE_BEFORE_AFTER=true
FEATURE_PRICE_ESTIMATOR=true
FEATURE_ACCEPTING_BOOKINGS=true
FEATURE_BLOG_ENGINE=true
FEATURE_BLOG_NOTIFY=true
